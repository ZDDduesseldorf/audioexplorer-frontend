    "sigma": "^3.0.3",
    "wavesurfer.js": "^7.12.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "1.60.0",
    "@types/howler": "^2.2.13",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "prettier": "^3.8.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^8.0.16",
    "vitest": "4.1.8"
